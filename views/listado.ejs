<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listado de Personal - Biblioteca UCM</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container mt-4">
        <h1>Personal Auxiliar - Biblioteca UCM</h1>

        <nav class="mb-4">
            <a href="/listado" class="btn btn-secondary">Ver todos</a>
            <a href="/alta" class="btn btn-success">Nuevo personal</a>
            <a href="/accesibilidad" class="btn btn-info">Accesibilidad</a>
        </nav>

        <!-- FILTROS -->
        <div class="card mb-4">
            <div class="card-header">
                <h5>Filtros</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Filtro por turno (Query String - GET) -->
                    <div class="col-md-4">
                        <form action="/listado" method="GET">
                            <label for="turno" class="form-label">Filtrar por turno:</label>
                            <select name="turno" id="turno" class="form-select" onchange="this.form.submit()">
                                <option value="">-- Todos --</option>
                                <option value="mañana" <%= turnoSeleccionado === 'mañana' ? 'selected' : '' %>>Mañana</option>
                                <option value="tarde" <%= turnoSeleccionado === 'tarde' ? 'selected' : '' %>>Tarde</option>
                            </select>
                        </form>
                    </div>

                    <!-- Filtro por identificador (URL Paramétrica) -->
                    <div class="col-md-4">
                        <label for="selectId" class="form-label">Filtrar por persona:</label>
                        <select id="selectId" class="form-select" onchange="if(this.value) window.location.href='/listado/' + this.value">
                            <option value="">-- Seleccionar --</option>
                            <% todosPersonal.forEach(function(p) { %>
                                <option value="<%= p.id %>"><%= p.id %> - <%= p.nombre %></option>
                            <% }); %>
                        </select>
                    </div>

                    <!-- Filtro por nombre (POST) -->
                    <div class="col-md-4">
                        <form action="/listado" method="POST">
                            <label for="nombre" class="form-label">Buscar por nombre:</label>
                            <div class="input-group">
                                <input type="text" name="nombre" id="nombre" class="form-control"
                                       placeholder="Escribe un nombre..." value="<%= nombreBuscado %>">
                                <button type="submit" class="btn btn-primary">Buscar</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- LISTADO -->
        <% if (personal.length === 0) { %>
            <div class="alert alert-warning">No se encontraron resultados.</div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% personal.forEach(function(p) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body text-center">
                                <% if (p.imagen && p.imagen !== '') { %>
                                    <img src="/imagenes/<%= p.imagen %>" alt="<%= p.nombre %>"
                                         class="rounded-circle mb-3"
                                         style="width: 80px; height: 80px; object-fit: cover;"
                                         onerror="this.onerror=null; this.src='/imagenes/noUser.png';">
                                <% } else { %>
                                    <img src="/imagenes/noUser.png" alt="Sin imagen"
                                         class="rounded-circle mb-3"
                                         style="width: 80px; height: 80px; object-fit: cover;">
                                <% } %>
                                <h5 class="card-title mb-1"><%= p.nombre %></h5>
                                <p class="card-text text-muted small mb-1"><%= p.email %></p>
                                <p class="card-text text-muted small mb-2">#<%= p.id %></p>
                                <span class="badge <%= p.turno === 'mañana' ? 'bg-warning text-dark' : 'bg-primary' %>">
                                    <%= p.turno %>
                                </span>
                            </div>
                            <div class="card-footer d-flex justify-content-center gap-2">
                                <a href="/editar/<%= p.id %>" class="btn btn-sm btn-warning">Editar</a>
                                <a href="/eliminar/<%= p.id %>" class="btn btn-sm btn-danger"
                                   onclick="return confirm('¿Estás seguro de eliminar a <%= p.nombre %>?')">Eliminar</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>

        <p class="text-muted">Total de registros mostrados: <%= personal.length %></p>
    </div>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
